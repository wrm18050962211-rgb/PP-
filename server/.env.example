# Local API
PORT=8787

# Storage driver
# Local MVP: json
# Tencent Cloud PostgreSQL migration: postgres
STORE_DRIVER=json
STORE_PATH=server/data/store.json
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/pp_platform

# Tencent COS media upload policy
COS_BUCKET=pp-mvp-local-1250000000
COS_REGION=ap-shanghai
COS_PUBLIC_BASE_URL=https://pp-mvp-local-1250000000.cos.ap-shanghai.myqcloud.com

# WeChat Mini Program auth and payment placeholders
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=
